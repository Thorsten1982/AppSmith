  "tableData": "{{\n  Bewaesserung_Lesen.data.filter(row => {\n    // 1. Status-Prüfung\n    const stat = String(row.Status || \"\").trim();\n    const istNichtFertig = stat !== \"Fertig\";\n    \n    // 2. Um das Problem mit 3.10 -> 3.1 zu lösen:\n    // Wir lassen die Ventilnummer explizit als String und vergleichen sie nur als Text.\n    // Falls du hier noch nach einem bestimmten Ventil filterst, schreibe es so:\n    // String(row.Ventil).trim() === \"3.10\" \n    \n    return istNichtFertig;\n  })\n}}",
