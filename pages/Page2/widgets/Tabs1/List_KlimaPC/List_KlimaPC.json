  "listData": "{{\n  Bewaesserung_Lesen.data.filter(row => {\n    // 1. Status-Filter: Nur anzeigen, was NICHT \"Fertig\" ist\n    const stat = String(row.Status || \"\").trim();\n    if (stat === \"Fertig\") return false;\n\n    // 2. System-Filter: Nur anzeigen, was im Store ausgewählt ist\n    // Wenn nichts ausgewählt ist, zeige alles an.\n    const gewaehltesSystem = appsmith.store.aktivSystem;\n    if (!gewaehltesSystem) return true;\n\n    const zeilenSystem = String(row.System || \"\").trim();\n    return zeilenSystem === gewaehltesSystem;\n  })\n}}",
