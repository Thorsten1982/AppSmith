  "listData": "{{\n  Bewaesserung_Lesen.data\n    .map((row, index) => {\n      // Wir berechnen den echten Index aus Google Sheets (Appsmith nutzt 0-basierten Index, Google Sheets startet bei 2 für die erste Datenzeile)\n      return {\n        ...row,\n        echterIndex: row.rowIndex !== undefined ? row.rowIndex : (index + 2)\n      };\n    })\n    .filter(row => {\n      // 1. Status-Filter\n      const stat = String(row.Status || \"\").trim();\n      if (stat === \"Fertig\") return false;\n\n      // 2. System-Filter\n      const gewaehltesTab = String(Tabs_System_Auswahl.selectedTab || \"\").trim();\n      if (!gewaehltesTab || gewaehltesTab === \"undefined\" || gewaehltesTab === \"\") return true;\n\n      const match = gewaehltesTab.match(/\\d+/);\n      const filterWert = match ? match[0] : gewaehltesTab;\n\n      const zeilenSystem = String(row.System || \"\").trim();\n      return zeilenSystem === filterWert;\n    })\n}}",
